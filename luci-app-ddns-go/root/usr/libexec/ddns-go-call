 #!/bin/sh

case "$1" in
    "get_logs")
        logread -l 200 | grep ddns-go || echo "No ddns-go logs found"
        ;;
    "clear_logs")
        /etc/init.d/log restart
        echo "Logs cleared"
        ;;
    *)
        echo "Usage: $0 {get_logs|clear_logs}"
        exit 1
        ;;
esac
